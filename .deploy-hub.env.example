# Hub deploy config — used by supplemental/scripts/deploy-hub.sh
# cp .deploy-hub.env.example .deploy-hub.env

# SSH target (user@host)
DEPLOY_REMOTE=root@xxx

# SSH port (default 22)
DEPLOY_SSH_PORT=22

# Extra ssh options, e.g. -i ~/.ssh/id_ed25519
# DEPLOY_SSH_OPTS=

# Where docker compose lives on the server
DEPLOY_COMPOSE_DIR=/root/beszel

# Synced source + remote docker build context
DEPLOY_SRC_DIR=/root/beszel/src

# Local dev image tag (not pushed to registry)
DEPLOY_HUB_IMAGE=ghcr.io/ahmetmakal/beszel/beszel:dev

# Optional: linux/amd64 when building on Apple Silicon with --load
# DEPLOY_PLATFORM=linux/amd64

# Frontend build: auto | local | remote | skip
# DEPLOY_FRONTEND=auto
