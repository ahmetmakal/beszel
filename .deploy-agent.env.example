# Agent deploy config — used by supplemental/scripts/deploy-agent.sh
# cp .deploy-agent.env.example .deploy-agent.env

# SSH target (user@host)
DEPLOY_AGENT_REMOTE=root@xxx

# SSH port (default 22)
DEPLOY_SSH_PORT=22

# Extra ssh options, e.g. -i ~/.ssh/id_ed25519
# DEPLOY_SSH_OPTS=

# Must match systemd ExecStart (check: systemctl cat beszel-agent)
DEPLOY_AGENT_BIN=/opt/beszel-agent/beszel-agent

DEPLOY_AGENT_SERVICE=beszel-agent
DEPLOY_AGENT_OS=linux
DEPLOY_AGENT_ARCH=amd64
